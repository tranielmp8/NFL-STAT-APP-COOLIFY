{
	"name": "nfl-stat-app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"db:push": "drizzle-kit push --config=drizzle.config.ts",
		"db:generate": "drizzle-kit generate --config=drizzle.config.ts",
		"db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
		"db:studio": "drizzle-kit studio --config=drizzle.config.ts",
		"db:seed": "node --env-file-if-exists=.env --experimental-strip-types scripts/seed-teams.mjs",
		"db:seed:settings": "node --env-file-if-exists=.env --experimental-strip-types scripts/seed-settings.mjs",
		"admin:promote": "node --env-file-if-exists=.env --experimental-strip-types scripts/promote-admin.mjs",
		"sync:rosters": "node --env-file-if-exists=.env --experimental-strip-types scripts/sync-espn-rosters.mjs",
		"sync:stats": "node --env-file-if-exists=.env --experimental-strip-types scripts/sync-espn-stats.mjs",
		"sync:schedules": "node --env-file-if-exists=.env --experimental-strip-types scripts/sync-espn-schedules.mjs",
		"sync:worker": "node --env-file-if-exists=.env --experimental-strip-types scripts/sync-worker.mjs",
		"sync:worker:once": "node --env-file-if-exists=.env --experimental-strip-types scripts/sync-worker.mjs --once",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"dependencies": {
		"better-auth": "~1.4.21",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"postgres": "^3.4.9"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^22",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	}
}
